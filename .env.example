# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=demo-secret-key-change-in-production

# Database
DB_PATH=./data/app.db

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# OCR Service
OCR_SERVICE_URL=http://localhost:8001

# VAHAN (mock for demo — replace with real values post-govt agreement)
VAHAN_MODE=mock
# VAHAN_API_URL=https://vahan.parivahan.gov.in/api
# VAHAN_API_KEY=your-key-here

# Aadhaar (mock for demo)
AADHAAR_MODE=mock
# AADHAAR_API_URL=
# AADHAAR_API_KEY=

# Notifications (mock for demo)
NOTIFICATION_MODE=mock
# SMS_PROVIDER=textlocal
# SMS_API_KEY=

# Demo settings
DEMO_OTP=123456
DEMO_MODE=true
